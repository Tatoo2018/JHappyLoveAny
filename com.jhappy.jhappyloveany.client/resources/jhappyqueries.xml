<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE queries [
   <!ELEMENT queries (#PCDATA|query)*>

   <!ATTLIST queries
    completionMatch (prefix | contains | fuzzy) "prefix"
    >

  <!ELEMENT query (#PCDATA)>

  <!ATTLIST query
    filepath CDATA #REQUIRED
    trim     (yes | no) "yes"
    description CDATA #IMPLIED
    type (xml | properties) #REQUIRED
    >
]>

<queries completionMatch="contains">

     <query filepath="src/.*/[^/]+\.xml$" type="xml">
        <![CDATA[//@key ]]>
    </query>

    <query filepath="src/.*/[^/]+\.properties$$" trim="yes" type="properties" />


</queries>